<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="rotating_puck">
    
    <link name="base_fixed">
    </link>

    <link name="base_link">
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00166</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.00166</iyy>
          <iyz>0</iyz>
          <izz>0.0025</izz>
        </inertia>
      </inertial>

      <visual name="puck_visual">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.2 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>

      <visual name="tracking_dot">
        <pose>0.02 0 0.013 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.005</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>1 0 0 1</ambient>
          <diffuse>1 0 0 1</diffuse>
          <specular>1 1 1 1</specular>
        </material>
      </visual>

      <collision name="puck_collision">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>

        <drake:proximity_properties>
          <drake:rigid_hydroelastic/>
          <drake:mesh_resolution_hint>0.01</drake:mesh_resolution_hint>
        </drake:proximity_properties>
      </collision>
    </link>

    <joint name="puck_revolute_joint" type="revolute">
      <parent>base_fixed</parent>
      <child>base_link</child>
      <pose>0 0 0 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>

        <dynamics>
          <damping>0.1</damping>
          <friction>0.05</friction>
        </dynamics>
      </axis>
    </joint>

  </model>
</sdf>